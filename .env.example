# ============================================
# Forgiving Cloak Configuration
# Copy this file to .env and fill in the values
# ============================================

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key
# Encryption key for IMAP credentials at rest (Fernet key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# --- Database ---
DATABASE_URL=sqlite:///./data/forgivingcloak.db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Set to false in production
DEBUG=true
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Have I Been Pwned (Optional) ---
# Get your API key at https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# --- Gmail OAuth (Optional) ---
# Create OAuth credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Scanning ---
# Max concurrent connections for site probing
MAX_PROBE_CONCURRENCY=5
# Delay between IMAP fetches (seconds)
IMAP_FETCH_DELAY=0.5
# Max emails to scan (0 = unlimited)
IMAP_MAX_EMAILS=10000
